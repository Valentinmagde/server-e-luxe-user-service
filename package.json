    "@types/express": "^4.17.17",
    "@types/express-session": "^1.18.2",
    "@types/fast-json-patch": "^1.1.5",
    "@types/i18n": "^0.13.6",
    "@types/jest": "^29.5.1",
    "@types/multer": "^1.4.11",
    "@types/node": "^18.16.16",
    "@types/supertest": "^2.0.12",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/validatorjs": "^3.15.0",
